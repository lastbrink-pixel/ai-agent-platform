# Copy this file to .env and fill in real values. NEVER commit the real .env.

# --- LLM providers (used by LiteLLM) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# --- LiteLLM ---
LITELLM_MASTER_KEY=change-me
LITELLM_PORT=4000

# --- n8n ---
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=change-me-32-chars

# --- Open WebUI ---
OPEN_WEBUI_PORT=3000
WEBUI_SECRET_KEY=change-me

# --- SearXNG ---
SEARXNG_PORT=8080
SEARXNG_SECRET=change-me

# --- cmd_server ---
CMD_SERVER_PORT=9999
CMD_SERVER_TOKEN=change-me   # shared secret so only your agents can call it
POSTGRES_PASSWORD=change-me
